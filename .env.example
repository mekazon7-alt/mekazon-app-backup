# ── Mekazon api-server environment ──────────────────────────────────────────
# Copy to your host's secret store (e.g. Render → Environment). NEVER commit real values.

PORT=5000

# Twilio Verify (phone OTP) — REQUIRED for real OTP. From the Twilio Console.
TWILIO_ACCOUNT_SID=AC_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_secret_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VA_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Session signing — REQUIRED for order history. Any long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# Shopify Admin API (OPTIONAL) — links a verified phone to a Shopify customer
# so the app can show order history / re-order / saved addresses.
# Without these, OTP login still works; it just won't attach a customer id.
SHOPIFY_STORE_DOMAIN=bbpdqw-tj.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_ADMIN_API_VERSION=2024-10

# Database (already used elsewhere in the api-server)
DATABASE_URL=postgres://user:password@host:5432/dbname